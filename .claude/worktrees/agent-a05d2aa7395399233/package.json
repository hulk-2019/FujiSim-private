{
  "name": "fujisim",
  "description": "A cross-platform desktop application for high-fidelity Fujifilm film simulation, built with Tauri 2, Rust, React 18, and TypeScript.",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri",
    "build:mac": "rm -rf src-tauri/target/universal-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target universal-apple-darwin --bundles dmg",
    "build:mac-arm": "rm -rf src-tauri/target/aarch64-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target aarch64-apple-darwin --bundles dmg",
    "build:mac-x64": "rm -rf src-tauri/target/x86_64-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-apple-darwin --bundles dmg",
    "build:win": "rm -rf src-tauri/target/x86_64-pc-windows-msvc/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.2",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
