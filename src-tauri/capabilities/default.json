{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FujiSim default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:path:default",
    "core:event:default",
    "core:app:default",
    "core:resources:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$DATA/FujiSim/**" }]
    },
    "shell:default"
  ]
}
