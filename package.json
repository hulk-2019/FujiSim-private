{
  "name": "fotoforge",
  "description": "A cross-platform desktop application for high-fidelity Fotofilm film simulation, built with Tauri 2, Rust, React 18, and TypeScript.",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri",
    "build:mac": "rm -rf src-tauri/target/universal-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target universal-apple-darwin --bundles app,dmg",
    "build:mac-arm": "rm -rf src-tauri/target/aarch64-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target aarch64-apple-darwin --bundles app,dmg",
    "build:mac-x64": "rm -rf src-tauri/target/x86_64-apple-darwin/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-apple-darwin --bundles app,dmg",
    "build:win": "rm -rf src-tauri/target/x86_64-pc-windows-msvc/release/bundle && PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-pc-windows-msvc",
    "gen:keypair": "echo '⚠️  此命令将覆盖现有密钥！老用户将无法收到新更新。' && pnpm tauri signer generate -w ~/.tauri/fotoforge.key && echo '✅ 已生成。请立即将 ~/.tauri/fotoforge.key{,.pub} 备份到离线介质（U 盘 / 1Password）'",
    "version:sync": "node scripts/bump-version.mjs",
    "prebuild:mac": "pnpm version:sync",
    "prebuild:mac-arm": "pnpm version:sync",
    "prebuild:mac-x64": "pnpm version:sync",
    "prebuild:win": "pnpm version:sync",
    "publish:update": "node scripts/publish-update.mjs"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-resizable-panels": "^4.11.0",
    "react-router-dom": "^6.30.3",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "ali-oss": "^6.23.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
